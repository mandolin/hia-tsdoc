{
  "name": "@hia-doc/tsdoc-runner",
  "version": "0.1.0",
  "description": "Standalone TypeScript/TSDoc project runner and CLI.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.mjs"
  },
  "bin": {
